# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite file. Mount a persistent volume here in production.
DB_PATH=/data/tracker.db

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_64_char_random_hex_string

# ── CORS ─────────────────────────────────────────────────────────────────────
# Exact origin of the frontend (e.g. https://app.viraltrack.org).
# Leave unset to disable CORS (same-origin only).
ALLOWED_ORIGIN=https://app.example.com

# ── Application URL ───────────────────────────────────────────────────────────
# Used for Stripe success/cancel redirect URLs and portal return URL.
APP_URL=https://app.example.com

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Apify (Instagram scraping) ────────────────────────────────────────────────
APIFY_TOKEN=your_apify_token

# ── Instagram session cookie (optional — for age-restricted accounts) ─────────
INSTAGRAM_SESSION_ID=your_instagram_session_id

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token

# ── Google OAuth (optional — enables "Sign in with Google") ──────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_CALLBACK_URL=https://app.example.com/auth/google/callback

# ── Google Service Account (Google Sheets integration) ────────────────────────
# Paste the full contents of the service account JSON key file as a single line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret from the Stripe dashboard (Developers → Webhooks).
# Without this, webhook signature verification is skipped (dangerous in production).
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Operator bootstrap ────────────────────────────────────────────────────────
# On first boot, this email address is promoted to admin role automatically.
OPERATOR_ADMIN_EMAIL=admin@example.com

# ── Reddit outreach (optional) ────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
